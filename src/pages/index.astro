    <div class="about-container">
      <div class="avatar-wrapper">
        <img src={`${base}profile.png`} alt="Arvind Sagar" class="profile-avatar" />
      </div>
      <div class="about-bio">
        <h3>Hi, I'm Arvind Sagar</h3>
        <p>
          Passionate Computer Science student with a strong interest in cybersecurity and Linux systems.
          Enthusiastic about network security, system hardening, and building secure, scalable infrastructure,
          with a proactive mindset and a strong drive for continuous learning.
        </p>
        <p>
          📍 Sahyadri College of Engineering & Management, Mangalore &nbsp;|&nbsp;
          📧 <a href="mailto:arvindsagar7350@gmail.com">arvindsagar7350@gmail.com</a> &nbsp;|&nbsp;
          📞 +91-9380803604
        </p>
        <div class="tech-tags">
          <span class="tech-badge">JavaScript</span>
          <span class="tech-badge">Python</span>
          <span class="tech-badge">Bash</span>
          <span class="tech-badge">C/C++</span>
          <span class="tech-badge">React</span>
          <span class="tech-badge">Node.js</span>
          <span class="tech-badge">Docker</span>
          <span class="tech-badge">Linux</span>
          <span class="tech-badge">Nmap</span>
          <span class="tech-badge">Burp Suite</span>
          <span class="tech-badge">Metasploit</span>
          <span class="tech-badge">AWS</span>
          <span class="tech-badge">Nginx</span>
          <span class="tech-badge">Tailscale</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects and Competitions Section -->
  <section id="projects" class="portfolio-section">
    <h2>Projects & Competitions</h2>

    <div class="grid-1-2">
      <!-- Projects Grid -->
      <div>
        <h3>Projects</h3>
        <div style="display: flex; flex-direction: column; gap: 20px;">
          <div class="portfolio-card">
            <h3>Armed Forces Welfare Management System</h3>
