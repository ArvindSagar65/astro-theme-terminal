  <!-- Articles & Writeups Section -->
  <section id="writings" class="portfolio-section">
    <h2>Articles & Writeups</h2>
    <div class="grid-2">

      <!-- Articles -->
      <div>
        <h3>📝 Articles</h3>
        <div class="competition-item">
          <div class="item-header">
            <span class="item-title">Coming Soon — Article Title</span>
            <span class="item-meta">~5 min read</span>
          </div>
          <p class="item-detail">
            A short description of what this article covers. Topics may include cybersecurity, Linux, networking, or developer tools.
          </p>
          <p style="margin-top: 8px; font-size: 0.9rem;">
            <a href="#" style="font-weight: bold; text-decoration: underline; opacity: 0.5; pointer-events: none;">Read Article ↗</a>
          </p>
        </div>
      </div>

      <!-- Writeups -->
      <div>
        <h3>🔐 CTF Writeups</h3>
        <div class="competition-item">
          <div class="item-header">
            <span class="item-title">Coming Soon — Challenge Name</span>
            <span class="item-meta">HackTheBox / TryHackMe</span>
          </div>
          <p class="item-detail">
            Writeup for a CTF challenge covering exploitation techniques, tools used, and step-by-step methodology.
          </p>
          <p style="margin-top: 8px; font-size: 0.9rem;">
            <a href="#" style="font-weight: bold; text-decoration: underline; opacity: 0.5; pointer-events: none;">Read Writeup ↗</a>
